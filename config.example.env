# Binance API (read-only keys — no trade/withdraw permissions needed)
BINANCE_API_KEY=your_read_only_api_key_here
BINANCE_API_SECRET=your_read_only_api_secret_here

# Claude AI (for natural language insights)
ANTHROPIC_API_KEY=your_anthropic_key_here
# AI model — run 'models' command to see all options
# Recommended: claude-haiku-4-5-20251001 (fast/cheap) or claude-sonnet-4-6 (best quality)
AI_MODEL=claude-haiku-4-5-20251001your_anthropic_key_here

# Telegram Bot (optional — for bot mode)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_USER_ID=your_telegram_user_id_here

# Language: en (English) or nl (Nederlands)
LANGUAGE=en

# User preferences
RISK_PROFILE=moderate       # conservative / moderate / aggressive
BASE_CURRENCY=USDT
FIAT_CURRENCY=EUR
DCA_BUDGET_MONTHLY=500      # Monthly DCA budget in FIAT_CURRENCY
